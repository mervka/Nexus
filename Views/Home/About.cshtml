@{
    ViewData["Title"] = "About";
}

<section class="about-page">
    <div class="about-intro card">
        <div class="card-body">
            <h2>About NEXUS</h2>

            <p>
                NEXUS is a collaboration platform where users can share early-stage project ideas,
                discover active projects, apply to contribute, and form teams after founder approval.
            </p>

            <p>
                The MVP focuses on a simple and clear workflow: profile completion, project sharing,
                application review, approval, and team visibility.
            </p>
        </div>
    </div>

    <div class="about-grid mt-4">
        <div class="about-card">
            <span>001</span>
            <h3>Share</h3>
            <p>Users create project ideas by describing the goal, audience, stage, and needed roles.</p>
        </div>

        <div class="about-card">
            <span>002</span>
            <h3>Explore</h3>
            <p>Other users discover active projects and review whether they want to contribute.</p>
        </div>

        <div class="about-card">
            <span>003</span>
            <h3>Apply</h3>
            <p>Interested users submit an application with their desired role, skills, and contribution plan.</p>
        </div>

        <div class="about-card">
            <span>004</span>
            <h3>Build</h3>
            <p>After founder approval, accepted users become team members and can view team profiles.</p>
        </div>
    </div>

    <div class="about-note mt-4">
        <strong>MVP Note:</strong>
        This version does not include real-time chat. The communication model is based on application,
        founder approval, and team/profile visibility.
    </div>
</section>