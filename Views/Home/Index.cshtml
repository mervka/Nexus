@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold">Creative ideas, collaborative teams</h1>

    <p class="lead mt-3">
        Share your project idea, discover skilled collaborators, and build your first team with clarity and confidence.
    </p>

    <div class="mt-4">
        <a class="btn btn-primary btn-lg me-2" asp-controller="Projects" asp-action="Create">
            Share an Idea
        </a>

        <a class="btn btn-outline-primary btn-lg" asp-controller="Explore" asp-action="Index">
            Explore Projects
        </a>
    </div>
</div>

<div class="row text-center mt-5">
    <div class="col-md-3">
        <h4>Define</h4>
        <p>Describe your idea, target users, project stage, and required roles.</p>
    </div>

    <div class="col-md-3">
        <h4>Connect</h4>
        <p>Discover people with the skills your project needs.</p>
    </div>

    <div class="col-md-3">
        <h4>Shape</h4>
        <p>Review applications and select suitable contributors.</p>
    </div>

    <div class="col-md-3">
        <h4>Implement</h4>
        <p>Build your team and move your idea toward an MVP.</p>
    </div>
</div>