@model Nexus.Models.Project

@{
    ViewData["Title"] = "Project Details";
}

<h1>@Model.Title</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success mt-3">
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning mt-3">
        @TempData["ErrorMessage"]
    </div>
}

<p class="text-muted">
    Explore this project idea and review whether you want to contribute.
</p>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title">@Model.ShortDescription</h5>

        <div class="alert alert-info mt-3">
            Detailed project information is visible after founder approval.
        </div>

        <hr />

        <p><strong>Target Audience:</strong> @Model.TargetAudience</p>
        <p><strong>Category:</strong> @Model.Category</p>
        <p><strong>Stage:</strong> @Model.Stage</p>
        <p><strong>Needed Roles:</strong> @Model.NeededRoles</p>
        <p><strong>Collaboration Type:</strong> @Model.CollaborationType</p>

        <hr />

        <p>
            <strong>Founder:</strong>
            @(string.IsNullOrWhiteSpace(Model.Founder.FullName) ? "Profile not completed" : Model.Founder.FullName)
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.Founder.ProfessionalTitle))
        {
            <p><strong>Founder Title:</strong> @Model.Founder.ProfessionalTitle</p>
        }

        <div class="mt-4">
            <a asp-controller="Explore" asp-action="Apply" asp-route-id="@Model.Id" class="btn btn-primary">
                Apply to Project
            </a>

            <a asp-controller="Explore" asp-action="Index" class="btn btn-secondary">
                Back to Explore
            </a>
        </div>
    </div>
</div>