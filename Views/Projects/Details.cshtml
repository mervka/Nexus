@model Nexus.Models.Project

@{
    ViewData["Title"] = "Project Details";
}

<h1>@Model.Title</h1>

<p class="text-muted">
    Your role in this project: <strong>@ViewBag.UserRole</strong>
</p>

<div class="card mt-4">
    <div class="card-body">
        <h5 class="card-title">@Model.ShortDescription</h5>

        <p class="mt-3">@Model.Description</p>

        <hr />

        <p><strong>Problem Statement:</strong> @Model.ProblemStatement</p>
        <p><strong>Target Audience:</strong> @Model.TargetAudience</p>
        <p><strong>Category:</strong> @Model.Category</p>
        <p><strong>Stage:</strong> @Model.Stage</p>
        <p><strong>Needed Roles:</strong> @Model.NeededRoles</p>
        <p><strong>Collaboration Type:</strong> @Model.CollaborationType</p>
        <p><strong>Status:</strong> @(Model.IsActive ? "Active" : "Inactive")</p>
        <p><strong>Created At:</strong> @Model.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</p>

        <hr />

        <p><strong>Founder:</strong> @Model.Founder.FullName</p>
        <p><strong>Founder Email:</strong> @Model.Founder.Email</p>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back to Projects</a>