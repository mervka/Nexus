@model List<Nexus.ViewModels.ProjectListItemViewModel>

@{
    ViewData["Title"] = "Projects";
}

<h1>Projects</h1>

<p class="text-muted">
    These are the projects you created or joined as an accepted team member.
</p>

<a asp-action="Create" class="btn btn-primary mb-4">Share a New Idea</a>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You do not have any projects yet.
    </div>
}
else
{
    <div class="row">
        @foreach (var project in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@project.Title</h5>

                        <p class="card-text">@project.ShortDescription</p>

                        <p class="mb-1">
                            <strong>Your role:</strong> @project.RoleInProject
                        </p>

                        <p class="mb-1">
                            <strong>Category:</strong> @project.Category
                        </p>

                        <p class="mb-1">
                            <strong>Stage:</strong> @project.Stage
                        </p>

                        <p class="mb-3">
                            <strong>Status:</strong> @(project.IsActive ? "Active" : "Inactive")
                        </p>

                        <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-outline-primary">
                            View Details
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}