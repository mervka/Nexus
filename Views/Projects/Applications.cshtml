@model Nexus.ViewModels.ProjectApplicationsViewModel

@{
    ViewData["Title"] = "Project Applications";
}

<h1>Applications</h1>

<p class="text-muted">
    Applications for: <strong>@Model.ProjectTitle</strong>
</p>

<a asp-action="Details" asp-route-id="@Model.ProjectId" class="btn btn-secondary mb-4">
    Back to Project
</a>

@if (!Model.Applications.Any())
{
    <div class="alert alert-info">
        There are no applications for this project yet.
    </div>
}
else
{
    <div class="row">
        @foreach (var application in Model.Applications)
        {
            <div class="col-md-12 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@application.ApplicantName</h5>

                        <p class="text-muted">@application.ApplicantEmail</p>

                        <p>
                            <strong>Desired Role:</strong> @application.DesiredRole
                        </p>

                        <p>
                            <strong>Motivation:</strong> @application.MotivationMessage
                        </p>

                        <p>
                            <strong>Relevant Skills:</strong> @application.RelevantSkills
                        </p>

                        <p>
                            <strong>Contribution Plan:</strong> @application.ContributionPlan
                        </p>

                        <p>
                            <strong>Availability:</strong> @application.Availability
                        </p>

                        <p>
                            <strong>Status:</strong> @application.Status
                        </p>

                        <p>
                            <strong>Applied At:</strong> @application.AppliedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </p>

                        @if (application.Status == "Pending")
                        {
                            <div class="mt-3">
                                <button class="btn btn-success" disabled>Accept</button>
                                <button class="btn btn-danger" disabled>Reject</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}