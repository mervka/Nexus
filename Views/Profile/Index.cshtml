@model Nexus.Models.ApplicationUser

@{
    ViewData["Title"] = "Profile";
}

<h1>My Profile</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning mt-3">
        @TempData["ErrorMessage"]
    </div>
}
else if (string.IsNullOrWhiteSpace(Model.FullName) ||
         string.IsNullOrWhiteSpace(Model.Bio) ||
         string.IsNullOrWhiteSpace(Model.Skills) ||
         string.IsNullOrWhiteSpace(Model.ExperienceLevel) ||
         string.IsNullOrWhiteSpace(Model.Email))
{
    <div class="alert alert-warning mt-3">
        Please complete your profile before applying to projects. Founders use your profile information to evaluate your applications.
    </div>
}

<div class="card mt-4">
    <div class="card-body">
        <h3>
            @(string.IsNullOrWhiteSpace(Model.FullName) ? "Profile not completed" : Model.FullName)
        </h3>

        @if (!string.IsNullOrWhiteSpace(Model.ProfessionalTitle))
        {
            <p class="text-muted">@Model.ProfessionalTitle</p>
        }

        @if (!string.IsNullOrWhiteSpace(Model.Bio))
        {
            <p>@Model.Bio</p>
        }
        else
        {
            <p class="text-muted">Bio not provided yet.</p>
        }

        <hr />

        <p>
            <strong>Email:</strong>
            @(string.IsNullOrWhiteSpace(Model.Email) ? "Not provided yet" : Model.Email)
        </p>
        <p>
            <strong>Skills:</strong>
            @(string.IsNullOrWhiteSpace(Model.Skills) ? "Not provided yet" : Model.Skills)
        </p>

        <p>
            <strong>Experience Level:</strong>
            @(string.IsNullOrWhiteSpace(Model.ExperienceLevel) ? "Not provided yet" : Model.ExperienceLevel)
        </p>
        <p><strong>Open to Collaboration:</strong> @(Model.IsOpenToCollaboration ? "Yes" : "No")</p>

        @if (!string.IsNullOrWhiteSpace(Model.PortfolioUrl))
        {
            <p><strong>Portfolio:</strong> <a href="@Model.PortfolioUrl" target="_blank">@Model.PortfolioUrl</a></p>
        }

        @if (!string.IsNullOrWhiteSpace(Model.GitHubUrl))
        {
            <p><strong>GitHub:</strong> <a href="@Model.GitHubUrl" target="_blank">@Model.GitHubUrl</a></p>
        }

        @if (!string.IsNullOrWhiteSpace(Model.LinkedInUrl))
        {
            <p><strong>LinkedIn:</strong> <a href="@Model.LinkedInUrl" target="_blank">@Model.LinkedInUrl</a></p>
        }

        <a asp-action="Edit" class="btn btn-primary mt-3">Edit Profile</a>
    </div>
</div>